// Analyzer test: type inference for various expressions
let integer = 42
let float = 3.14
let text = "hello"
let flag = true
let nothing: void = void

let nullable: string? = "hello"
let defaulted = nullable ?? "fallback"

let list = [1, 2, 3]
let length = list.len()

let obj = { "name": "Kim", "age": 30 }

function add(a: i32, b: i32) -> i32 {
  a + b
}

let result = add(1, 2)
