// Design tokens and theme definitions
@design {
  @theme {
    @color "primary" "#3B82F6"
    @color "secondary" "#10B981"
    @color "background" "#FFFFFF"

    @size "sm" "0.875rem"
    @size "md" "1rem"
    @size "lg" "1.25rem"

    @font "body" "Inter, sans-serif"
    @font "heading" "Cal Sans, sans-serif"

    @spacing "xs" "0.25rem"
    @spacing "sm" "0.5rem"
    @spacing "md" "1rem"
  }
}
