// Runtime test: static HTML page rendering
@html {
  @head {
    @title "Test Page"
    @meta %charset="utf-8"
  }
  @body {
    @div %class="container" {
      @h1 "Hello, World!"
      @p "This is a test page rendered by orv."
      @vstack {
        @span "Item 1"
        @span "Item 2"
      }
    }
  }
}
