// Runtime test: basic server with JSON response
@server {
  @listen 8080

  @route GET /api/health {
    @respond 200 { "status": "ok" }
  }

  @route POST /api/echo {
    let data = @body
    @respond 200 { "echo": data }
  }

  @route GET /api/users/:id {
    let userId = @param "id"
    @respond 200 { "id": userId }
  }
}
