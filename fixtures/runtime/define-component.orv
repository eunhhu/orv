// Runtime test: define components with children
pub define Card(title: string) -> @html {
  @div %class="card" {
    @h2 "{title}"
    @div %class="card-body" {
      @children
    }
  }
}

pub define Page() -> @html {
  @body {
    @Card %title="Welcome" {
      @p "This is inside the card."
    }
  }
}
