pub define DS() -> @design {
  @color "primary" "#007bff"

  @font "sm" "Pretendard" "14px"
  @font "md" "Pretendard" "16px"
  @font "lg" "Pretendard" "18px"

  @size "xs" "4px"
  @size "sm" "8px"
  @size "md" "16px"
  @size "lg" "32px"
  @size "xl" "64px"

  @theme "light" {
    @color "background" "#ffffff"
    @color "foreground" "#000000"
  }
  @theme "dark" {
    @color "background" "#000000"
    @color "foreground" "#ffffff"
  }
}
