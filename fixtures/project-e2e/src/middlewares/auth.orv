import jwt

const SECRET = @env SECRET ?? "jwt-secret-key"

pub define Auth() -> @before {
  let token = @cookie get "ssid0"
  let payload = jwt.verify(token, SECRET) ?? void
  @context set { payload }
}

pub define Guard() -> @before {
  let payload = @context get "payload"
  if !payload {
    @respond 401 { message: "Authorization failed" }
  }
}