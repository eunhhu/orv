// ERROR: .fetch() on route with :id but no param provided
@server {
  @listen 3000

  let getUser = @route GET /api/users/:id {
    @respond 200 { "name": "Kim" }
  }

  @route GET / {
    @serve @html {
      @body {
        @button "Load" %onClick={
          // Missing param={ id: "42" } argument
          let user = await getUser.fetch()
        }
      }
    }
  }
}
